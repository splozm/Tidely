<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="@dimen/spacing_md">

    <!-- Event Type (HIGH/LOW) -->
    <TextView
        android:id="@+id/tvEventType"
        android:layout_width="45dp"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Tidely.Label"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        tools:text="HIGH"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Event Label (Next high / Following high) -->
    <TextView
        android:id="@+id/tvEventLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:textAppearance="@style/TextAppearance.Tidely.Label"
        android:textColor="@color/text_tertiary"
        tools:text="Next high"
        app:layout_constraintStart_toEndOf="@id/tvEventType"
        app:layout_constraintEnd_toStartOf="@id/tvTime"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Time -->
    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Tidely.TideTime"
        android:textSize="22sp"
        android:layout_marginEnd="@dimen/spacing_md"
        tools:text="14:32"
        app:layout_constraintEnd_toStartOf="@id/tvHeight"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Height -->
    <TextView
        android:id="@+id/tvHeight"
        android:layout_width="50dp"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Tidely.Label"
        android:textColor="@color/text_secondary"
        android:gravity="end"
        tools:text="5.2 m"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Divider (Light) -->
    <View
        android:layout_width="0dp"
        android:layout_height="0.5dp"
        android:background="@color/border_light"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
